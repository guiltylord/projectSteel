          "type": "fill",
          "selector": "input.css-x527hy-Textfield",
          "arg_index": 0
        },
        {
          "type": "dropdown",
          "selector": "input.vs__search",
          "opt_selector": ".vs__dropdown-option",
          "arg_index": 1
        },
        {
          "type": "click",
          "selector": "button.css-1dem7su-Button"
        }
      ],
      "captcha": {
        "image": ".css-1i8blrw-CaptchaImage img",
