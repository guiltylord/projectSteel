{
    "fssp_new": {
      "url": "https://fssp.gov.ru/iss/ip_search",
      "actions": [
        {
          "type": "click",
          "selector": "role:textbox"
        },
        {
          "type": "fill",
          "selector": "role:textbox",
          "arg_index": 0
        },
        {
          "type": "click",
          "selector": "placeholder:Все регионы"
        },
        {
          "type": "fill",
          "selector": "placeholder:Все регионы",
          "arg_index": 1
        },
        {
          "type": "press",
          "selector": "placeholder:Все регионы",
          "key": "Enter"
        },
        {
          "type": "click",
          "selector": "role:button[name='Найти']"
        },
        {
          "type": "click",
          "selector": "role:textbox[name='Введите код']"
        }
      ],
      "captcha": {
        "input": "role:textbox[name='Введите код']",
        "submit": "role:button[name='Отправить']",
        "max_tries": 10
      }
    }
  }