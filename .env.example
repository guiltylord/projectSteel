# =================================================================
# ТЕХНИЧЕСКАЯ КОНФИГУРАЦИЯ (СЕЛЕКТОРЫ САЙТА)
# =================================================================

# URL страницы с формой
C0=https://target-site.com/search

# Селекторы текстовых полей (напр. Фамилия, Имя, Отчество)
C1=input[name="field_1"]
C2=input[name="field_2"]
C3=input[name="field_3"]

# Селектор выпадающего списка (Dropdown / Select)
C4=#dropdown_id

# Селектор поля ввода даты
C5=#date_input_id

# Селектор кнопки запуска основного поиска
C6=button#submit_search

# Селектор поля ввода капчи (в модальном окне)
C7=#captcha_input_field

# Селектор изображения капчи
C8=#captcha_image_id

# Значение по умолчанию для выпадающего списка (если не задано в D5)
C9=10

# Максимальное количество попыток разгадывания капчи
C10=5

# Селектор кнопки подтверждения капчи (в модальном окне)
C11=#captcha_submit_button


# =================================================================
# ДАННЫЕ ДЛЯ ВВОДА (ДАННЫЕ ПОЛЬЗОВАТЕЛЯ)
# =================================================================

# Значения для текстовых полей C1, C2, C3
D1=Ivanov
D2=Ivan
D3=Ivanovich

# Значение для поля даты C5 (в формате ДД.ММ.ГГГГ)
D4=01.01.1990

# Выбранный пункт для списка C4 (ID элемента категории)
D5=77